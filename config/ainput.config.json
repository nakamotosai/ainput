{
  "shortcuts": {
    "push_to_talk": "Alt+Z",
    "screen_capture": "Alt+X",
    "mouse_middle_hold_enabled": false
  },
  "startup": {
    "launch_at_login": true
  },
  "asr": {
    "model_dir": "models/sense-voice",
    "provider": "cpu",
    "sample_rate_hz": 16000,
    "language": "auto",
    "use_itn": true,
    "num_threads": 4
  },
  "capture": {
    "auto_save_to_desktop": false
  },
  "output": {
    "prefer_direct_paste": true,
    "fallback_to_clipboard": true
  },
  "logging": {
    "level": "info",
    "file_name": "ainput.log"
  }
}
